{
  "name": "@soccit/scoring",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Soccit off-chain scoring engine + leaderboard projector. Joins on-chain predictions with TxLINE substitutions and projects a live ranked leaderboard.",
  "exports": {
    "./leaderboard/schema": "./src/leaderboard/leaderboard.schema.ts",
    "./leaderboard/service": "./src/leaderboard/leaderboard.service.ts",
    "./leaderboard/errors": "./src/leaderboard/leaderboard.errors.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.2",
    "mongodb": "^6.12.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
