{
  "name": "@soccit/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Soccit off-chain worker: TxLINE SL12 ingestor (Phase 2). Scoring + settlement keeper land in later phases.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "subscribe:onchain": "tsx scripts/subscribe-onchain.ts",
    "subscribe": "tsx scripts/subscribe.ts",
    "fixtures": "tsx scripts/fixtures.ts"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.2",
    "mongodb": "^6.12.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "tweetnacl": "^1.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "overrides": {
      "uuid": "^9.0.1"
    }
  }
}
