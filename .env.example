MONGO_DB=soccit
LOG_LEVEL=info

# Solana cluster: "devnet" (default) or "mainnet-beta".
SOLANA_CLUSTER=devnet
# RPC URL resolution: SOLANA_RPC_URL wins if set; otherwise a Helius URL is built
# from SOLANA_CLUSTER + HELIUS_API_KEY. One of the two is REQUIRED to boot any
# Solana-touching service (api/scoring/worker/settlement) — there is no silent fallback.
SOLANA_RPC_URL=
HELIUS_API_KEY=
PROGRAM_ID=TbxGzvqiuNfeV8GAoP2unFwjTu1Ry7hjnaesCorJm9v
# Settlement USDC mint. Defaults per cluster (devnet mock / mainnet canonical USDC).
USDC_MINT=

# Worker / TxLINE live ingest
TXLINE_BASE_URL=https://txline.txodds.com
TXLINE_API_TOKEN=
TXLINE_TX_SIG=
TXLINE_FIXTURE_ID=
TERMINAL_ACTIONS=game_finalised

# Scoring
SCORING_FIXTURE_ID=900001
PREDICTIONS_SOURCE=file
PREDICTIONS_FILE=infra/e2e/predictions.local.json
REFRESH_INTERVAL_MS=5000

# Settlement keeper. Do not commit the referenced keypair file.
PLATFORM_WALLET=
RESOLVER_KEYPAIR_PATH=./secrets/resolver-keypair.json
POLL_INTERVAL_MS=5000

ENTRY_FEE_BASE_UNITS=5000000
